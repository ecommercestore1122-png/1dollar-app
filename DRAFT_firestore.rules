rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- USERS ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (
        // Action: Update Profile
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'shopName', 'paymentInfo'])
      );
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.role in ['customer', 'reseller', 'supplier']
        && data.pendingBalance == 0
        && data.availableBalance == 0;
    }

    // --- PRODUCTS ---
    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (incoming().role == 'supplier' || isAdmin());
      allow update, delete: if isAdmin() || (isSignedIn() && existing().supplierId == request.auth.uid);
    }

    // --- ORDERS (The Escrow Heart) ---
    match /orders/{orderId} {
      allow get: if isSignedIn() && (
        isOwner(resource.data.customerId) || 
        isOwner(resource.data.resellerId) || 
        isOwner(resource.data.supplierId) || 
        isAdmin()
      );
      
      allow list: if isSignedIn() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.resellerId == request.auth.uid || 
        resource.data.supplierId == request.auth.uid
      );

      allow create: if isSignedIn() && isValidOrder(incoming());
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        // Action: Accept (Supplier Only)
        (isOwner(existing().supplierId) && 
         existing().status == 'placed' && 
         incoming().status == 'accepted' && 
         incoming().supplierDeadline == request.time + duration.value(72, 'h') &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'supplierDeadline', 'updatedAt'])) ||
        
        // Action: Ship (Supplier Only)
        (isOwner(existing().supplierId) && 
         existing().status == 'accepted' && 
         incoming().status == 'shipped' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
        
        // Action: Dispute (Reseller/Customer)
        ((isOwner(existing().resellerId) || isOwner(existing().customerId)) && 
         incoming().status == 'disputed' && 
         incoming().paymentLocked == true &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paymentLocked', 'updatedAt']))
      );
    }

    function isValidOrder(data) {
      return data.resellerId == request.auth.uid 
        && data.status == 'placed'
        && data.paymentLocked == true
        && data.wholesalePrice > 0
        && data.resellerProfit >= 0;
    }

    // --- DISPUTES ---
    match /orders/{orderId}/disputes/{disputeId} {
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid ||
        get(/databases/$(database)/documents/orders/$(orderId)).data.resellerId == request.auth.uid ||
        get(/databases/$(database)/documents/orders/$(orderId)).data.supplierId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && incoming().initiatorId == request.auth.uid;
    }
  }
}
